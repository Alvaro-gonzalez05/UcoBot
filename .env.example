# =====================================================
# UcoBot — Variables de entorno
# Copiá este archivo a `.env` y completá con tus valores.
# El `.env` real está en .gitignore y NUNCA debe commitearse.
# =====================================================

# --- Supabase ---
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_HOST=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Web Push (VAPID) ---
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Google Gemini (IA para demos / onboarding) ---
GEMINI_DEMO_API_KEY=

# --- Meta App (WhatsApp + Instagram) ---
# Verify token único para ambos webhooks (lo elegís vos, cualquier string)
WEBHOOK_VERIFY_TOKEN=

# System User Access Token (Business Manager → Usuarios del sistema)
# Token permanente para enviar mensajes a todos los clientes vía Embedded Signup
WHATSAPP_SYSTEM_TOKEN=

# Credenciales de la app en developers.facebook.com
META_APP_ID=
META_APP_SECRET=
NEXT_PUBLIC_META_APP_ID=

# Config ID de Embedded Signup (WhatsApp → Tech Provider → Configurations)
NEXT_PUBLIC_WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=

# Versión de la Graph API
META_GRAPH_VERSION=v21.0
NEXT_PUBLIC_META_GRAPH_VERSION=v21.0

# --- Mercado Pago (suscripción de UcoBot) ---
# Access Token de tu app en mercadopago.com/developers (TEST para probar, APP_USR de producción para cobrar de verdad)
MP_ACCESS_TOKEN=
# Precio mensual del abono en ARS (opcional, default 90000)
MP_SUBSCRIPTION_PRICE=90000
# Clave secreta del webhook (MP → Webhooks). Opcional pero recomendada para validar la firma.
MP_WEBHOOK_SECRET=
# URL pública de la app (para los back_url de Mercado Pago). En prod: tu dominio real.
NEXT_PUBLIC_APP_URL=

# --- Mercado Pago OAuth (Parte B: que tus clientes conecten SU cuenta) ---
# Credenciales de una SEGUNDA app de MP (tipo marketplace/Checkout Pro, con OAuth)
MP_OAUTH_CLIENT_ID=
MP_OAUTH_CLIENT_SECRET=
